{
  "name": "root",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "e2e/example",
      "examples/*"
    ],
    "nohoist": [
      "**/expo",
      "**/expo/**"
    ]
  },
  "license": "MIT",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format:check": "npx prettier --check .",
    "format": "npx prettier --write .",
    "type-check": "npm run type-check --workspaces --if-present",
    "check": "run-s lint format:check type-check test:unit",
    "test": "run-s test:*",
    "test:unit": "npm run test --workspaces --if-present",
    "test:e2e": "cypress run",
    "test:db": "cd packages/db && npm test",
    "release": "node scripts/release.js",
    "default-changeset": "node scripts/create-default-changeset.js",
    "changeset": "npx changeset",
    "bump": "npx changeset version",
    "publish": "npx changeset publish",
    "clean": "npx rimraf node_modules && npm run clean:workspace",
    "clean:workspace": "npm run clean --workspace=*",
    "reinstall": "npm run clean && npm install",
    "copy-readme": "cp README.md packages/db/README.md",
    "build-aggregator": "cd packages/aggregator && npm run build",
    "build-components": "cd packages/examples-components && npm run build; cd ../../",
    "build-db": "cd packages/db && npm run build; cd ../../",
    "build-auth-server": "cd packages/auth-server && npm run build",
    "build-examples": "run-p build-example:*",
    "build-example:basic": "cd examples/example-basic && npm run build",
    "build-example:multi-room": "cd examples/example-multi-room && npm run build",
    "build-example:interop-notes": "cd examples/example-interop-notes && npm run build",
    "build-example:interop-flashcards": "cd examples/example-interop-flashcards && npm run build",
    "build-shared": "cd packages/shared && npm run build; cd ../../",
    "build": "run-s build-shared build-db build-auth-server build-aggregator build-components build-example:*",
    "dev": "run-p dev:*",
    "dev:docker": "docker compose -f docker-compose.dev.yml up",
    "dev:docker:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:docker:clean": "docker compose -f docker-compose.dev.yml down -v",
    "dev:aggregator": "cd packages/aggregator && DATABASE_URL=postgresql://eweser:changeme@localhost:5499/eweser npm run dev",
    "dev:sync-server-a": "SYNC_PORT=38181 SYNC_DB_PATH=/tmp/eweser-sync-a.sqlite SYNC_AUTH_SECRET=dev-sync-secret tsx packages/sync-server/src/index.ts",
    "dev:sync-server-b": "SYNC_PORT=38182 SYNC_DB_PATH=/tmp/eweser-sync-b.sqlite SYNC_AUTH_SECRET=dev-sync-secret tsx packages/sync-server/src/index.ts",
    "dev:example-aggregator": "cd examples/example-aggregator && npm run dev",
    "dev:aggregator-demo": "run-p dev:sync-server-a dev:sync-server-b dev:example-aggregator",
    "dev:db": "cd packages/db && npm run dev",
    "dev:auth-server": "cd packages/auth-server && npm run dev",
    "dev:shared": "cd packages/shared && npm run dev",
    "dev:example-basic": "cd examples/example-basic && npm run dev",
    "dev:example-multi-room": "cd examples/example-multi-room && npm run dev",
    "dev:example-interop-notes": "cd examples/example-interop-notes && npm run dev",
    "dev:example-interop-flashcards": "cd examples/example-interop-flashcards && npm run dev",
    "dev-e2e": "cypress open",
    "ci-build": "rm -rf package-lock.json && npm install @esbuild/linux-x64 && npm run build",
    "ci-start": "run-p run-auth-server run-example-previews",
    "start-test-rpc-server": "cd test-rpc-server; node server.js",
    "run-example-previews": "run-p run-example-preview:*",
    "run-example-preview:basic": "cd examples/example-basic; npm run preview",
    "run-example-preview:multi-room": "cd examples/example-multi-room; npm run preview",
    "run-example-preview:interop-notes": "cd examples/example-interop-notes; npm run preview",
    "run-example-preview:interop-flashcards": "cd examples/example-interop-flashcards; npm run preview",
    "run-auth-server": "cd packages/auth-server; npm run start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@testing-library/cypress": "^10.1.0",
    "cypress": "^15.6.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.20.1",
    "idb": "^8.0.3",
    "inquirer": "^12.11.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.1",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.9"
  },
  "volta": {
    "node": "20.11.0"
  },
  "dependencies": {
    "react-native-uuid": "^2.0.3"
  }
}
