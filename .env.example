# EweserDB Environment Variables
# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -hex 32

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=eweser
POSTGRES_PASSWORD=changeme          # CHANGE THIS in production
POSTGRES_DB=eweser

# ─── Auth API ──────────────────────────────────────────────────────────────────
# Random secrets — generate each with: openssl rand -hex 32
SERVER_SECRET=localserversecret1234567890abcdef
BETTER_AUTH_SECRET=localbetterauthsecret1234567890ab

# ─── Sync Server ───────────────────────────────────────────────────────────────
SYNC_AUTH_SECRET=localsyncauthsecret1234567890abcd # Same value used in auth-api and sync-server

# ─── Aggregator ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=dev-webhook-secret   # Shared secret between sync-server and aggregator
# TRUSTED_PEERS=eweser.com|https://aggregator.eweser.com/api|secret1,peer2|https://peer2.example.com/api|secret2

# ─── Domain (self-hosted Docker Compose only) ──────────────────────────────────
# Set to your domain for Caddy to obtain TLS certs and serve on 80/443.
# Caddy serves:
#   yourdomain.com        → landing page + auth + API + sync
#   notes.yourdomain.com  → Ewe Note app
DOMAIN=localhost

# ─── Local development ports ───────────────────────────────────────────────────
AUTH_SERVER_PORT=38100
AUTH_API_PORT=38101
EXAMPLE_BASIC_PORT=38110
CADDY_HOST_PORT=38180

# ─── Public URLs for the Docker Compose stack ──────────────────────────────────
# Self-hosted example: https://eweser.example.com
# DO App Platform: https://<app-name>.ondigitalocean.app
AUTH_PUBLIC_URL=http://localhost:38180
AUTH_PUBLIC_DOMAIN=localhost:38180
AUTH_TRUSTED_ORIGINS=http://localhost:38101,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5181,http://127.0.0.1:5181,http://localhost:38111,http://127.0.0.1:38111
SYNC_PUBLIC_URL=ws://localhost:38180/sync
DATABASE_URL=postgresql://eweser:changeme@localhost:5499/eweser

# ─── Observability (optional — Axiom) ─────────────────────────────────────────
# Get your token at axiom.co → Settings → API Tokens
# Create datasets at axiom.co → Settings → Datasets (type: Events / Metrics)
# AXIOM_API_KEY=
# AXIOM_EVENTS_DATASET=eweser-db-events
# AXIOM_METRICS_DATASET=eweser-db-metrics

# ─── Dev-only ─────────────────────────────────────────────────────────────────
# Dozzle: browser log viewer at http://localhost:9999
DOZZLE_PORT=9999

# MCP agent auth
EWESER_AGENT_TOKEN=
