EWESER_AGENT_TOKEN=your-agent-token-here
EWESER_AUTH_URL=http://localhost:3001
EWESER_AGGREGATOR_URL=http://localhost:38190
# Optional worktree namespace for memory docs, e.g. current folder name.
# EWESER_WORKTREE_TAG=worktree:eweser-db
# EWESER_SYNC_URL overrides the sync server URL returned by the auth server.
# Required in local dev if Caddy proxy is not running (auth server may return
# the Caddy port instead of the direct Hocuspocus port).
# EWESER_SYNC_URL=ws://localhost:38181/sync
