{
  "name": "@eweser/examples-components",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "typescript-watch": "tsc --watch",
    "vite-build-watch": "vite build --watch",
    "dev": "run-p vite-build-watch typescript-watch",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "preview": "vite preview"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/examples-components.es.js",
      "require": "./dist/examples-components.umd.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "./dist/examples-components.umd.js",
  "module": "./dist/examples-components.es.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@eweser/db": "^1.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "@eweser/db": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eweser/eslint-config-react-ts": "^1.15.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
