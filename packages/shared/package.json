{
  "name": "@eweser/shared",
  "version": "1.15.0",
  "description": "shared types and helpers for @eweser/db and other @eweser packages",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "homepage": "https://github.com/eweser/eweserdb",
  "author": "jacobcoro",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eweser/eweserdb.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/dist",
    "/src"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf ./dist; tsc && node ./fix-esm-extensions.mjs dist",
    "dev": "tsc -w",
    "clean": "rm -rf ./dist",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test-watch": "vitest",
    "test": "vitest --run"
  },
  "peerDependencies": {
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@eweser/eslint-config-ts": "^1.15.0",
    "eslint": "^9.39.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yjs": "^13.6.30",
    "yjs-types": "^0.0.1"
  },
  "gitHead": "d6ee91d84092583f851548fa9ffe8ccf5de5705a"
}
