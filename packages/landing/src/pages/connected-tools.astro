---
import Layout from '../layouts/Layout.astro';

const appUrl = (
  import.meta.env.RAILWAY_SERVICE_APP_URL ??
  import.meta.env.APP_URL ??
  'https://app.eweser.com'
).replace(/\/$/, '');
const signInUrl = `${appUrl}/sign-in`;
const aiSignInUrl = `${appUrl}/sign-in?redirect=%2Fai`;
const noteUrl = 'https://note.eweser.com/';
const termsUrl = `${appUrl}/statement/terms-of-service`;
const privacyUrl = `${appUrl}/statement/privacy`;
const abuseEmail = 'abuse@eweser.com';

const availableTools = [
  {
    action: 'Open Ewe Note',
    description:
      'The shipped note-taking proof point for user-owned rooms and local-first sync.',
    href: noteUrl,
    path: 'App sign-in and notes access grant',
    title: 'Ewe Note',
  },
  {
    action: 'Sign in to set up',
    description:
      'Local desktop setup using the Eweser MCP server and token-backed access.',
    href: aiSignInUrl,
    path: 'Token-backed MCP setup',
    title: 'Claude Desktop',
  },
  {
    action: 'Sign in to connect',
    description:
      'Remote HTTP MCP connection through the authenticated Eweser OAuth path.',
    href: aiSignInUrl,
    path: 'OAuth remote MCP',
    title: 'Claude web',
  },
  {
    action: 'Sign in to connect',
    description:
      'ChatGPT connector setup through the authenticated Eweser MCP endpoint.',
    href: aiSignInUrl,
    path: 'OAuth remote MCP',
    title: 'ChatGPT web',
  },
  {
    action: 'Sign in to set up',
    description:
      'Token-backed agent access for development workflows that need scoped data reads.',
    href: aiSignInUrl,
    path: 'Token-backed setup',
    title: 'GitHub Copilot',
  },
  {
    action: 'Sign in to set up',
    description:
      'Token-backed setup for Codex workflows that need permissioned Eweser data.',
    href: aiSignInUrl,
    path: 'Token-backed setup',
    title: 'Codex',
  },
  {
    action: 'Sign in to set up',
    description:
      'Token-backed fallback path for local or experimental agent clients.',
    href: aiSignInUrl,
    path: 'Token-backed setup',
    title: 'OpenClaw',
  },
];

const developerPaths = ['@eweser/db', '@eweser/mcp', 'Self-hostable auth and sync services'];
const comingLater = ['More focused apps', 'Richer app permission dashboard', 'File storage providers'];
---

<Layout
  title="Connected Tools — EweserDB"
  description="Preview available EweserDB apps and MCP access paths. Sign in to connect tools, set up AI clients, and manage permissions."
>
  <header class="border-b border-slate-200 bg-white px-6 py-5">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-6">
      <a href="/" class="flex items-center gap-3">
        <img src="/eweser-logo.svg" alt="" aria-hidden="true" class="h-8 w-8" />
        <span class="text-lg font-semibold tracking-tight text-slate-950">EweserDB</span>
      </a>
      <nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex">
        <a href="/" class="transition-colors hover:text-slate-950">Home</a>
        <a href="https://docs.eweser.com" target="_blank" rel="noreferrer" class="transition-colors hover:text-slate-950">Docs</a>
        <a href={signInUrl} class="transition-colors hover:text-slate-950">Sign in</a>
      </nav>
    </div>
  </header>

  <main class="bg-white text-slate-900">
    <section class="px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <p class="mb-5 text-xs font-semibold uppercase tracking-[0.28em] text-[#d62d20]">Connected Tools</p>
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
          <div>
            <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-slate-950 sm:text-6xl">
              Let apps and AI agents ask permission.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
              Start with Ewe Note, connect supported AI clients, or build a focused app on top of the same user-owned data layer.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
            <p class="text-sm font-semibold text-slate-950">Signed-out preview</p>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Tools are visible here before sign-in. Actual MCP setup flows, OAuth prompts, token generation, status badges, and revoke controls stay behind the authenticated app shell.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f5f2ec] px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <h2 class="text-3xl font-bold tracking-tight text-slate-950">Available now</h2>
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {availableTools.map((tool) => (
            <article class="flex min-h-[260px] flex-col rounded-2xl border border-stone-300 bg-white p-6 shadow-[6px_6px_0px_rgba(17,17,17,0.08)]">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#d62d20]">{tool.path}</p>
                <h3 class="mt-4 text-xl font-semibold text-slate-950">{tool.title}</h3>
                <p class="mt-3 text-sm leading-6 text-stone-600">{tool.description}</p>
              </div>
              <a
                href={tool.href}
                class="mt-auto inline-flex h-10 items-center justify-center rounded-xl bg-slate-950 px-4 text-sm font-medium text-white transition-colors hover:bg-slate-800"
              >
                {tool.action}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-2">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Developer paths</h2>
          <div class="mt-6 grid gap-3">
            {developerPaths.map((path) => (
              <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 font-mono text-sm text-slate-700">{path}</div>
            ))}
          </div>
        </div>
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Coming later</h2>
          <div class="mt-6 grid gap-3">
            {comingLater.map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">{item}</div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white px-6 py-10 text-slate-600">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <img src="/eweser-logo.svg" alt="" aria-hidden="true" class="h-6 w-6" />
        <span class="font-semibold tracking-tight text-slate-950">EweserDB</span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm font-medium">
        <a href={signInUrl} class="transition-colors hover:text-slate-950">Sign in</a>
        <a href={noteUrl} class="transition-colors hover:text-slate-950">Ewe Note</a>
        <a href={termsUrl} class="transition-colors hover:text-slate-950">Terms</a>
        <a href={privacyUrl} class="transition-colors hover:text-slate-950">Privacy</a>
        <a href={`mailto:${abuseEmail}`} class="transition-colors hover:text-slate-950">Abuse</a>
      </div>
    </div>
  </footer>
</Layout>
