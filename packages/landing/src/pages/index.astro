---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    glyph: '01',
    title: 'AI + MCP Access',
    description:
      'Give agents controlled access to your data without copy-pasting your life into chat windows.',
  },
  {
    glyph: '02',
    title: 'Collaborative Notes',
    description:
      'Work together in real time with offline-first sync and conflict-free CRDT merging.',
  },
  {
    glyph: '03',
    title: 'Knowledge Base',
    description:
      'Keep structured notes, links, and documents in a system other apps can understand.',
  },
  {
    glyph: '04',
    title: 'Study Tools',
    description:
      'Turn notes into flashcards, summaries, and spaced repetition flows without export gymnastics.',
  },
  {
    glyph: '05',
    title: 'Publishing',
    description:
      'Reuse the same data across sites, docs, newsletters, and knowledge portals.',
  },
  {
    glyph: '06',
    title: 'Team Memory',
    description:
      'Share decisions, references, and working knowledge without locking the team into one interface forever.',
  },
];

const devFeatures = [
  {
    title: 'Type-safe schemas',
    description: 'Strongly typed collections, documents, and _ref links keep interop practical instead of theoretical.',
  },
  {
    title: 'Real-time CRDT sync',
    description: 'IndexedDB locally, Yjs for conflict-free collaboration, and Hocuspocus for live transport.',
  },
  {
    title: 'MCP-ready access',
    description: 'Connect Claude Desktop, ChatGPT, or your own agent workflows through scoped MCP access.',
  },
  {
    title: 'No prison backend',
    description: 'Point apps at eweser.com or a self-hosted homeserver without inventing another proprietary island.',
  },
  {
    title: 'Shared app interop',
    description: 'Build against shared schemas when you want ecosystem compatibility, or extend with private models.',
  },
  {
    title: 'Self-hostable stack',
    description: 'Own the infra, run your own auth and sync services, and stay independent of anyone else’s moat.',
  },
];

const appsMcpCards = [
  {
    label: 'Live App',
    title: 'User-owned auth',
    description: 'Sign in, approve scopes, and keep trust visible.',
    accentClass: 'bg-[#d62d20]',
    metaClass: 'bg-[#a8a29e]',
    tileClass: 'bg-[#d62d20]',
    lineWidth: 'w-28',
    tailWidth: 'w-24',
  },
  {
    label: 'System View',
    title: 'Personal data',
    description: 'Collections, schemas, rooms, sync, sharing, and storage.',
    accentClass: 'bg-[#111111]',
    metaClass: 'bg-[#a8a29e]',
    tileClass: 'bg-[#f5f5f4]',
    lineWidth: 'w-20',
    tailWidth: 'w-20',
  },
  {
    label: 'Live App',
    title: 'Connected apps',
    description: 'Installed tools, granted access, recent usage, and revoke controls.',
    accentClass: 'bg-[#d62d20]',
    metaClass: 'bg-[#d62d20]',
    tileClass: 'bg-[#f5f5f4]',
    lineWidth: 'w-20',
    tailWidth: 'w-24',
  },
  {
    label: 'System View',
    title: 'MCP / AI access',
    description: 'Clients, permissions, metadata, audit-style visibility, and setup.',
    accentClass: 'bg-[#111111]',
    metaClass: 'bg-[#a8a29e]',
    tileClass: 'bg-[#f5f5f4]',
    lineWidth: 'w-20',
    tailWidth: 'w-24',
  },
];

const developerPills = ['Type-safe schemas', 'Real-time CRDT sync', 'Shared app interop', 'Self-hostable stack'];

const codeSnippet = `import { Database } from '@eweser/db';

const db = new Database({
  initialRooms: [{ collectionKey: 'notes', name: 'My Notes' }]
});

const room = db.getRoom('notes');
const Notes = room.getDocuments();

Notes.new({ text: 'Hello from any app' });`;

const noteUrl = 'https://note.eweser.com/';
const appUrl = (
  import.meta.env.RAILWAY_SERVICE_APP_URL ??
  import.meta.env.APP_URL ??
  'https://app.eweser.com'
).replace(/\/$/, '');
const signInUrl = `${appUrl}/sign-in`;
const connectAiUrl = `${appUrl}/sign-in?redirect=%2Fai`;
const termsUrl = `${appUrl}/statement/terms-of-service`;
const privacyUrl = `${appUrl}/statement/privacy`;
const abuseEmail = 'abuse@eweser.com';
---

<Layout
  title="EweserDB — Your data is not their moat."
  description="EweserDB is a local-first interoperable database for apps that refuse lock-in. Notes, agents, study tools, publishing workflows, and collaborative workspaces can all connect to the same user-owned data."
>
  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[#050505]/80 backdrop-blur-xl">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-3">
        <img src="/eweser-logo-white.svg" alt="" aria-hidden="true" class="h-8 w-8" />
        <span class="text-lg font-semibold tracking-tight text-white">EweserDB</span>
      </a>

      <nav class="hidden items-center gap-6 md:flex">
        <a href="#problem" class="text-sm text-slate-300 transition-colors hover:text-white">Manifesto</a>
        <a href="/connected-tools" class="text-sm text-slate-300 transition-colors hover:text-white">Connected Tools</a>
        <a href="#developers" class="text-sm text-slate-300 transition-colors hover:text-white">Developers</a>
        <a
          href="https://docs.eweser.com"
          target="_blank"
          rel="noreferrer"
          class="text-sm text-slate-300 transition-colors hover:text-white"
        >
          Docs
        </a>
      </nav>

      <div class="flex items-center gap-3">
        <a href={signInUrl} class="hidden text-sm text-slate-300 transition-colors hover:text-white md:inline-flex">
          Sign in
        </a>
        <a
          href={connectAiUrl}
          class="hidden items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-medium text-black transition-colors hover:bg-slate-100 sm:inline-flex"
        >
          Connect my AI
        </a>
      </div>
    </div>
  </header>

  <main>
    <section class="relative isolate overflow-hidden bg-[#050505] pt-32 pb-20 text-white sm:pt-36 sm:pb-28">
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(circle at top, rgba(255,255,255,0.12), transparent 42%);"
      ></div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[520px]"
        style="background: linear-gradient(180deg, rgba(74,222,128,0.12) 0%, rgba(5,5,5,0) 72%);"
      ></div>

      <div class="mx-auto grid w-full max-w-6xl gap-14 px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-12">
        <div class="min-w-0 max-w-2xl">
          <p class="mb-5 text-sm font-medium uppercase tracking-[0.28em] text-slate-400 sm:tracking-[0.32em]">
            Local-first database for user-owned software
          </p>
          <h1 class="max-w-xl text-4xl font-bold tracking-tight leading-[1.02] text-white sm:text-6xl lg:text-7xl">
            Your data
            <br />
            <span class="text-slate-400">is not</span>
            <br />
            their moat.
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-400 sm:text-xl">
            EweserDB is a local-first interoperable database for apps that refuse lock-in. Notes, agents, study
            tools, publishing workflows, and collaborative workspaces can all connect to the same user-owned data.
          </p>

          <div class="mt-10 flex min-w-0 flex-col gap-4 sm:flex-row">
            <a
              href={connectAiUrl}
              class="inline-flex w-full items-center justify-center rounded-xl bg-white px-6 py-3 font-medium text-black transition-colors hover:bg-slate-100 sm:w-auto"
            >
              Connect my AI
            </a>
            <a
              href={noteUrl}
              class="inline-flex w-full items-center justify-center rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5 sm:w-auto"
            >
              Try Ewe Note
            </a>
          </div>
        </div>

        <div class="relative min-w-0">
          <div
            class="absolute -left-6 top-10 h-24 w-24 rounded-full bg-emerald-400/20 blur-3xl float-slow"
            aria-hidden="true"
          ></div>
          <div
            class="absolute -right-4 bottom-12 h-32 w-32 rounded-full bg-white/10 blur-3xl float-fast"
            aria-hidden="true"
          ></div>

          <div class="relative w-full max-w-full overflow-hidden rounded-[1.75rem] border border-white/10 bg-[#101010] shadow-2xl shadow-black/40">
            <div class="flex items-center gap-2 border-b border-white/10 bg-[#151515] px-4 py-3">
              <span class="h-3 w-3 rounded-full bg-white/20"></span>
              <span class="h-3 w-3 rounded-full bg-white/20"></span>
              <span class="h-3 w-3 rounded-full bg-white/20"></span>
            </div>

            <div class="grid gap-6 p-6 sm:p-8">
              <div class="rounded-[1.35rem] border border-white/10 bg-[#151515] p-4 shadow-2xl float-slow">
                <div class="mb-4 text-xs font-mono uppercase tracking-[0.24em] text-slate-500">User Auth</div>
                <div class="space-y-3">
                  <div class="h-4 w-2/3 rounded bg-white/10"></div>
                  <div class="relative h-4 overflow-hidden rounded bg-emerald-400/15">
                    <div class="sheen absolute inset-y-0 left-0 w-1/2 bg-emerald-300/45"></div>
                  </div>
                  <div class="h-4 w-3/5 rounded bg-white/10"></div>
                </div>
              </div>

              <div class="flex items-center justify-center gap-4 text-emerald-400">
                <div class="flex h-12 w-12 items-center justify-center rounded-full border border-emerald-400/30">
                  <div class="h-2.5 w-2.5 rounded-full bg-emerald-400"></div>
                </div>
                <span class="text-xs font-mono uppercase tracking-[0.26em] text-emerald-300/80">User-owned data core</span>
              </div>

              <div class="rounded-[1.35rem] border border-white/10 bg-[#151515] p-4 shadow-2xl float-fast">
                <div class="mb-4 text-xs font-mono uppercase tracking-[0.24em] text-slate-500">MCP Access</div>
                <div class="space-y-3">
                  <div class="h-4 w-3/4 rounded bg-white/10"></div>
                  <div class="relative h-4 overflow-hidden rounded bg-emerald-400/15">
                    <div class="sheen absolute inset-y-0 left-0 w-1/2 bg-emerald-300/45"></div>
                  </div>
                  <div class="h-4 w-5/6 rounded bg-white/10"></div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="rounded-[1.1rem] border border-white/10 bg-white/5 p-3">
                  <div class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Personal Data</div>
                  <div class="mt-3 h-3 w-3/4 rounded bg-white/10"></div>
                  <div class="mt-2 h-3 w-1/2 rounded bg-emerald-400/20"></div>
                </div>
                <div class="rounded-[1.1rem] border border-white/10 bg-white/5 p-3">
                  <div class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Connected Apps</div>
                  <div class="mt-3 h-3 w-2/3 rounded bg-white/10"></div>
                  <div class="mt-2 h-3 w-1/2 rounded bg-emerald-400/20"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="problem" class="bg-white px-6 py-24 text-slate-900">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <h2 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">Apps became landlords.</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-500 sm:text-xl">
            Modern software treats your notes, decisions, documents, and knowledge like platform property.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:gap-10">
          <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 sm:p-10">
            <p class="mb-8 text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">The old world</p>
            <ul class="space-y-5">
              <li class="flex gap-4 text-lg leading-8 text-slate-700">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-rose-400"></span>
                Your work gets trapped in product-specific databases
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-700">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-rose-400"></span>
                Switching tools means rebuilding context from scratch
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-700">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-rose-400"></span>
                Collaboration requires everyone to join the same silo
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-700">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-rose-400"></span>
                AI agents cannot help unless your data is accessible
              </li>
            </ul>
          </div>

          <div class="rounded-[1.75rem] border border-emerald-400/20 bg-[#050505] p-8 text-white shadow-2xl shadow-black/30 sm:p-10">
            <p class="mb-8 text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">EweserDB world</p>
            <ul class="space-y-5">
              <li class="flex gap-4 text-lg leading-8 text-slate-200">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                You own the database
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-200">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                Apps compete to serve you
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-200">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                Offline first. Always available. Always yours.
              </li>
              <li class="flex gap-4 text-lg leading-8 text-slate-200">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                AI agents plug into user space through scoped MCP access
              </li>
            </ul>
          </div>
        </div>

        <p class="mx-auto mt-12 max-w-3xl text-center text-lg italic text-slate-500 sm:text-xl">
          "Own the substrate. Swap the interface."
        </p>
      </div>
    </section>

    <section id="features" class="bg-white px-6 py-24 text-slate-900">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16">
          <h2 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">A bigger playground for your data.</h2>
          <p class="mt-4 max-w-2xl text-lg text-slate-500 sm:text-xl">
            Notes are one proof point. The larger story is one user-owned data layer feeding AI tools, collaborative
            workspaces, study flows, publishing workflows, and team memory.
          </p>
        </div>

        <div class="grid gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
          {features.map((feature) => (
            <article class="flex flex-col">
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 text-sm font-semibold text-slate-700">
                {feature.glyph}
              </div>
              <h3 class="text-xl font-semibold text-slate-950">{feature.title}</h3>
              <p class="mt-3 max-w-sm text-slate-600 leading-7">{feature.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="apps-mcp" class="bg-[#f5f2ec] px-6 py-24 text-slate-900">
      <div class="mx-auto max-w-6xl">
        <div class="max-w-3xl">
          <p class="mb-5 text-xs font-semibold uppercase tracking-[0.28em] text-[#d62d20]">04 // Connected Tools</p>
          <h2 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">Let apps and agents ask permission.</h2>
          <p class="mt-4 text-lg text-slate-600 sm:text-xl">
            The landing page should preview the actual product: entry, ownership, permissions, and agent access.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-4">
          {appsMcpCards.map((card) => (
            <article class="rounded-[1.5rem] border border-stone-300 bg-white p-5 shadow-[6px_6px_0px_rgba(17,17,17,0.08)]">
              <span class:list={[
                'inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em]',
                card.label === 'Live App' ? 'bg-[#d62d20] text-white' : 'border border-black bg-[#f6f6f1] text-black',
              ]}>
                {card.label}
              </span>
              <h3 class="mt-4 text-lg font-semibold uppercase text-slate-950">{card.title}</h3>
              <p class="mt-2 text-sm leading-6 text-stone-600">{card.description}</p>

              <div class="mt-5 rounded-2xl bg-[#0f0f10] p-4">
                <div class:list={['h-2 rounded-full', card.accentClass, 'w-[70px]']}></div>
                <div class="mt-4 flex items-center gap-3">
                  <div class:list={['h-2 rounded-full bg-[#f5f5f4]', card.lineWidth]}></div>
                  <div class:list={['h-2 rounded-full', card.metaClass, card.tailWidth]}></div>
                  <div class:list={['h-4 w-4 rounded-md', card.tileClass]}></div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="developers" class="border-y border-white/10 bg-[#050505] px-6 py-24 text-white">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16">
          <p class="mb-6 inline-flex rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs font-mono font-medium uppercase tracking-[0.28em] text-emerald-300">
            For Developers
          </p>
          <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            Build the app. Not the prison.
          </h2>
          <p class="mt-4 max-w-2xl text-lg text-slate-400 sm:text-xl">
            Add <span class="text-emerald-300">@eweser/db</span> to your app. Shared schemas, CRDT sync, and
            MCP-ready access patterns give builders useful software without another proprietary island.
          </p>
        </div>

        <div class="grid min-w-0 items-start gap-8 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="min-w-0 space-y-6">
            <div class="min-w-0 overflow-hidden rounded-[1.5rem] border border-white/10 bg-[#111111] shadow-2xl shadow-black/30">
              <div class="flex items-center gap-2 border-b border-white/10 bg-white/5 px-4 py-3">
                <span class="h-3 w-3 rounded-full bg-rose-500/90"></span>
                <span class="h-3 w-3 rounded-full bg-amber-400/90"></span>
                <span class="h-3 w-3 rounded-full bg-emerald-400/90"></span>
                <span class="ml-3 text-xs font-mono uppercase tracking-[0.22em] text-slate-500">Terminal</span>
              </div>
              <div class="px-6 py-5">
                <code class="text-sm text-slate-200">$ npm install @eweser/db yjs</code>
              </div>
            </div>

            <div class="min-w-0 overflow-hidden rounded-[1.5rem] border border-white/10 bg-[#0c0c0c] shadow-2xl shadow-black/30">
              <div class="flex items-center gap-2 border-b border-white/10 bg-white/5 px-4 py-3">
                <span class="h-3 w-3 rounded-full bg-rose-500/90"></span>
                <span class="h-3 w-3 rounded-full bg-amber-400/90"></span>
                <span class="h-3 w-3 rounded-full bg-emerald-400/90"></span>
                <span class="ml-3 text-xs font-mono uppercase tracking-[0.22em] text-slate-500">app.ts</span>
              </div>
              <pre class="overflow-x-auto px-6 py-6 text-sm leading-7 text-slate-300"><code>{codeSnippet}</code></pre>
            </div>
          </div>

          <div class="grid min-w-0 gap-4 sm:grid-cols-2">
            {devFeatures.map((feature) => (
              <article class="min-w-0 rounded-[1.35rem] border border-white/10 bg-white/[0.03] p-6 transition-colors hover:bg-white/[0.06]">
                <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-400">{feature.description}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="mt-12 flex flex-wrap gap-3">
          {developerPills.map((pill) => (
            <span class="rounded-full border border-white/10 bg-white/[0.06] px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200">
              {pill}
            </span>
          ))}
        </div>
      </div>
    </section>

    <section id="try" class="bg-[#050505] px-6 py-24 text-white">
      <div class="mx-auto max-w-6xl rounded-[2rem] border border-white/10 bg-[#0b0b0b] px-8 py-14 shadow-2xl shadow-black/40 sm:px-12">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <div class="flex items-center gap-4">
            <img src="/eweser-logo-white.svg" alt="" aria-hidden="true" class="h-14 w-14" />
            <span class="text-xl font-semibold tracking-tight text-white">EweserDB</span>
          </div>

          <div>
            <h2 class="max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
              Better tools should not require starting over.
            </h2>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-400">
              Try the ecosystem, read the docs, or deploy your own user-owned stack.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href={noteUrl}
                class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 font-medium text-black transition-colors hover:bg-slate-100"
              >
                Try the demo
              </a>
              <a
                href="https://docs.eweser.com"
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5"
              >
                Read the docs
              </a>
              <a
                href="https://railway.app/new/template?template=https://github.com/eweser/eweser-db"
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5"
              >
                Self-host it
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white px-6 py-12 text-slate-600">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-8 md:flex-row">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <div class="flex items-center gap-2">
          <img src="/eweser-logo.svg" alt="" aria-hidden="true" class="h-6 w-6" />
          <span class="font-semibold tracking-tight text-slate-950">EweserDB</span>
        </div>
        <span class="text-sm italic text-slate-500">"Ewe-ser", pronounced "user". Because you are.</span>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 text-sm font-medium">
        <a href="https://github.com/eweser/eweser-db" target="_blank" rel="noreferrer" class="transition-colors hover:text-slate-950">
          GitHub
        </a>
        <a href="https://www.npmjs.com/package/@eweser/db" target="_blank" rel="noreferrer" class="transition-colors hover:text-slate-950">
          npm
        </a>
        <a href={signInUrl} class="transition-colors hover:text-slate-950">Sign in</a>
        <a href={noteUrl} class="transition-colors hover:text-slate-950">Ewe Note</a>
        <a href={termsUrl} class="transition-colors hover:text-slate-950">Terms</a>
        <a href={privacyUrl} class="transition-colors hover:text-slate-950">Privacy</a>
        <a href={`mailto:${abuseEmail}`} class="transition-colors hover:text-slate-950">Abuse</a>
      </div>

      <div class="flex flex-wrap justify-center gap-2">
        {['Yjs', 'Hocuspocus', 'better-auth', 'TypeScript', 'MIT'].map((tag) => (
          <span class="rounded-full border border-slate-200 bg-slate-100 px-2.5 py-1 text-xs font-mono font-medium text-slate-600">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </footer>
</Layout>
