---
// Developer section — dark theme
const devFeatures = [
  {
    title: 'TypeScript-native',
    description:
      'Strongly-typed document schemas. Notes, flashcards, profiles — with _ref cross-links between collections.',
  },
  {
    title: 'Yjs CRDT under the hood',
    description:
      'Conflict-free, offline-tolerant sync. IndexedDB for local persistence. Hocuspocus WebSocket for real-time.',
  },
  {
    title: 'MCP server built-in',
    description:
      'Ship an AI-native app instantly. Users\' AI agents (Claude Desktop, VS Code Copilot) connect via @eweser/mcp — zero extra backend.',
  },
  {
    title: 'No backend required',
    description:
      'Point your app at eweser.com or any self-hosted homeserver. Auth, sync, and access control all handled.',
  },
  {
    title: 'Build on shared schemas',
    description:
      'Interoperate with other EweserDB apps out of the box. Or extend privately with your own document types.',
  },
  {
    title: 'Open source, MIT',
    description:
      'Full monorepo on GitHub. Self-host the whole stack. No dependency on our servers — ever.',
  },
];

const codeSnippet = `import { Database } from '@eweser/db';

const db = new Database({
  initialRooms: [{ collectionKey: 'notes', name: 'My Notes' }]
});

const room = db.getRoom('notes');
const Notes = room.getDocuments();

// Creates a note — syncs to all other apps
// the user has authorized automatically
Notes.new({ text: 'Hello from any app' });`;
---

<section id="developer" class="py-24 px-6 bg-gray-950 text-white">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6 inline-block bg-gray-800 text-gray-400 text-xs font-mono px-3 py-1 rounded-full uppercase tracking-widest">
      For Developers
    </div>
    <h2 class="text-3xl font-bold mb-4">Build interoperable apps in minutes</h2>
    <p class="text-gray-400 text-lg mb-12 max-w-2xl">
      Add <code class="text-green-400">@eweser/db</code> to your app. Users bring their own data. No backend required.
    </p>

    <div class="grid lg:grid-cols-2 gap-12 mb-16">
      <!-- Code block -->
      <div class="bg-gray-900 rounded-xl overflow-hidden border border-gray-800">
        <div class="flex gap-1.5 px-4 py-3 border-b border-gray-800">
          <span class="w-3 h-3 rounded-full bg-red-500"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
          <span class="w-3 h-3 rounded-full bg-green-500"></span>
        </div>
        <pre class="p-6 text-sm text-gray-300 overflow-x-auto leading-relaxed"><code>{codeSnippet}</code></pre>
      </div>

      <!-- Install command + quick stat -->
      <div class="flex flex-col justify-center gap-6">
        <div class="bg-gray-900 rounded-xl p-5 border border-gray-800 font-mono text-green-400 text-sm">
          $ npm install @eweser/db yjs
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          That's it. Your app now has a user-owned, offline-first, real-time collaborative database.
          No Supabase account. No Firebase billing surprises. The user's homeserver handles everything.
        </p>
      </div>
    </div>

    <!-- Dev feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {devFeatures.map((f) => (
        <div class="rounded-xl border border-gray-800 p-6 hover:border-gray-600 transition">
          <h3 class="font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>

    <!-- Philosophy pull quote -->
    <div class="mt-16 border-l-4 border-gray-600 pl-6">
      <p class="text-gray-300 text-lg italic mb-2">
        "Apps must compete on experience, not lock-in. Third parties can build new features on your users' data
        without needing permission from the original developer."
      </p>
      <p class="text-gray-500 text-sm">— EweserDB philosophy</p>
    </div>
  </div>
</section>
