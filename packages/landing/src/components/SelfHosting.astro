---
// Self-hosting CTA section
---

<section id="get-started" class="py-24 px-6 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Get started</h2>
    <p class="text-center text-gray-500 mb-12 text-lg">Your data, your server — or ours.</p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl p-8 border border-gray-200 flex flex-col">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">For users</p>
        <h3 class="text-xl font-bold mb-3">Try Ewe Note free</h3>
        <p class="text-gray-500 text-sm mb-6 flex-1">
          No sign-up friction. Works on our hosted server. Your data stays local in your browser first.
        </p>
        <a
          href="https://notes.eweser.com"
          class="bg-black text-white text-center px-6 py-3 rounded-lg font-semibold hover:bg-gray-800 transition"
        >
          Open Ewe Note →
        </a>
      </div>

      <div class="bg-white rounded-xl p-8 border border-gray-200 flex flex-col">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">For developers</p>
        <h3 class="text-xl font-bold mb-3">Deploy your own homeserver</h3>
        <p class="text-gray-500 text-sm mb-6 flex-1">
          One-click Railway deploy (~$5–15/mo) or run on any $6/mo VPS with a single shell command.
        </p>
        <div class="flex flex-col gap-3">
          <a
            href="https://railway.app/new/template?template=https://github.com/eweser/eweser-db"
            class="bg-black text-white text-center px-6 py-3 rounded-lg font-semibold hover:bg-gray-800 transition"
            target="_blank"
            rel="noopener noreferrer"
          >
            Deploy on Railway ↗
          </a>
          <a
            href="https://github.com/eweser/eweser-db"
            class="border border-gray-300 text-center px-6 py-3 rounded-lg font-semibold hover:border-gray-600 transition"
            target="_blank"
            rel="noopener noreferrer"
          >
            View on GitHub ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
