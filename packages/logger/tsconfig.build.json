{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["node"],
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src/**/*"]
}
