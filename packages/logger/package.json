{
  "name": "@eweser/logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared pino logger factory for EweserDB server packages",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@axiomhq/pino": "^1.6.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/host-metrics": "^0.38.3",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "pino": "^9.12.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@eweser/eslint-config-ts": "^1.15.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.39.1",
    "pino-pretty": "^13.1.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
