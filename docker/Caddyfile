# Main domain — landing, auth pages, API, sync
{$DOMAIN:localhost} {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; connect-src 'self' https: wss:; frame-src 'self' https://challenges.cloudflare.com; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com;"
    }

    @legacy_login {
        path /
        query redirect=*
        query domain=*
        query name=*
    }
    redir @legacy_login /auth/sign-in?{query} 302

    @auth_root path /auth
    redir @auth_root /auth/ 302

    handle /api/auth/* {
        reverse_proxy auth-api:3000
    }

    handle /api/* {
        reverse_proxy auth-api:3000
    }

    # MCP endpoint (ChatGPT, Claude web)
    handle /mcp {
        reverse_proxy auth-api:3000
    }
    handle /mcp/* {
        reverse_proxy auth-api:3000
    }

    # OAuth 2.0 Authorization Server
    handle /oauth/* {
        reverse_proxy auth-api:3000
    }

    # OAuth 2.0 discovery metadata
    handle /.well-known/* {
        reverse_proxy auth-api:3000
    }

    handle /ping {
        reverse_proxy auth-api:3000
    }

    handle /health {
        reverse_proxy auth-api:3000
    }

    @sync path /sync /sync/*
    handle @sync {
        uri strip_prefix /sync
        reverse_proxy sync-server:8080
    }

    handle /aggregator/* {
        uri strip_prefix /aggregator
        reverse_proxy aggregator:8090
    }

    @auth_pages path /auth/*
    handle @auth_pages {
        uri strip_prefix /auth
        root * /srv/auth-pages
        try_files {path} /index.html
        file_server
    }

    handle {
        root * /srv/landing
        try_files {path} {path}.html /index.html
        file_server
    }
}

# Notes subdomain — Ewe Note app
notes.{$DOMAIN:localhost} {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; connect-src 'self' https: wss:; frame-src 'self' https://challenges.cloudflare.com; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com;"
    }

    reverse_proxy ewe-note:80
}
