{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "EweserDB",
  "description": "Local-first, user-owned database with sync, auth, and notes",
  "icon": "https://eweser.com/favicon.ico",
  "readme": "README.md",
  "env": {
    "SERVER_SECRET": {
      "description": "Random secret for server sessions",
      "generator": "secret"
    },
    "BETTER_AUTH_SECRET": {
      "description": "Secret for Better Auth",
      "generator": "secret"
    },
    "SYNC_AUTH_SECRET": {
      "description": "Secret for sync server authentication",
      "generator": "secret"
    },
    "WEBHOOK_SECRET": {
      "description": "Secret for webhook signatures",
      "generator": "secret"
    }
  },
  "services": {
    "postgres": {
      "image": "postgres:16",
      "env": {
        "POSTGRES_USER": "eweser",
        "POSTGRES_PASSWORD": "${{secret}}",
        "POSTGRES_DB": "eweser"
      },
      "volumes": ["/var/lib/postgresql/data"]
    },
    "auth-api": {
      "source": {
        "repo": "eweser/eweser-db",
        "branch": "main",
        "root": "packages/auth-server-hono"
      },
      "env": {
        "DATABASE_URL": "postgresql://${{postgres.POSTGRES_USER}}:${{postgres.POSTGRES_PASSWORD}}@postgres.railway.internal:5432/${{postgres.POSTGRES_DB}}",
        "SERVER_SECRET": "${{env.SERVER_SECRET}}",
        "BETTER_AUTH_SECRET": "${{env.BETTER_AUTH_SECRET}}",
        "BETTER_AUTH_BASE_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "AUTH_SERVER_DOMAIN": "${{RAILWAY_PUBLIC_DOMAIN}}",
        "AUTH_SERVER_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "SYNC_SERVER_URL": "wss://sync-server.${{RAILWAY_PUBLIC_DOMAIN}}/sync",
        "SYNC_AUTH_SECRET": "${{env.SYNC_AUTH_SECRET}}"
      },
      "healthcheck": {
        "path": "/health",
        "timeout": 30
      }
    },
    "sync-server": {
      "source": {
        "repo": "eweser/eweser-db",
        "branch": "main",
        "root": "packages/sync-server"
      },
      "env": {
        "SYNC_AUTH_SECRET": "${{env.SYNC_AUTH_SECRET}}",
        "AGGREGATOR_WEBHOOK_URL": "https://aggregator.${{RAILWAY_PUBLIC_DOMAIN}}/webhooks/hocuspocus",
        "WEBHOOK_SECRET": "${{env.WEBHOOK_SECRET}}"
      }
    },
    "aggregator": {
      "source": {
        "repo": "eweser/eweser-db",
        "branch": "main",
        "root": "packages/aggregator"
      },
      "env": {
        "DATABASE_URL": "postgresql://${{postgres.POSTGRES_USER}}:${{postgres.POSTGRES_PASSWORD}}@postgres.railway.internal:5432/${{postgres.POSTGRES_DB}}",
        "SYNC_SERVER_URL": "wss://sync-server.${{RAILWAY_PUBLIC_DOMAIN}}/sync",
        "SYNC_AUTH_SECRET": "${{env.SYNC_AUTH_SECRET}}",
        "WEBHOOK_SECRET": "${{env.WEBHOOK_SECRET}}"
      }
    },
    "ewe-note": {
      "source": {
        "repo": "eweser/eweser-db",
        "branch": "main",
        "root": "packages/ewe-note"
      }
    },
    "auth-pages": {
      "source": {
        "repo": "eweser/eweser-db",
        "branch": "main",
        "root": "packages/auth-pages"
      }
    }
  }
}
