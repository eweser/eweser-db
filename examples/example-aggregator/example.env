# Copy to .env and adjust as needed.
VITE_SYNC_SERVER_A_URL=ws://localhost:38181
VITE_SYNC_SERVER_B_URL=ws://localhost:38182
VITE_AGGREGATOR_URL=http://localhost:38190

# Set this to your SYNC_AUTH_SECRET so the browser can sign JWTs locally.
# When set, the example app never calls /api/dev-token — sync connections work
# even when the aggregator is not running.
# Must match the SYNC_AUTH_SECRET used by both sync servers.
VITE_DEV_SYNC_SECRET=dev-sync-secret
